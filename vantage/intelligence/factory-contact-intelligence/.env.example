# VANTAGE Factory Contact Intelligence — Environment Variables
# Copy to .env and fill in. NEVER commit .env to git.

# ── Crawlee / Playwright ──────────────────────────────────────────────────────
# Delay between requests in milliseconds (respect robots.txt / rate limits)
CRAWL_REQUEST_DELAY_MS=2000
# Max concurrent requests per crawl run
CRAWL_MAX_CONCURRENCY=3
# Max retry attempts on failed requests
CRAWL_MAX_RETRIES=2
# User-agent string (set to a real browser UA — Crawlee sets a default)
CRAWL_USER_AGENT=

# ── SearXNG ───────────────────────────────────────────────────────────────────
# URL of your self-hosted SearXNG instance (see vendor/intelligence/searxng)
SEARXNG_BASE_URL=http://localhost:8080
# Optional API key if your SearXNG instance requires it
SEARXNG_API_KEY=

# ── theHarvester ─────────────────────────────────────────────────────────────
# Absolute path to the theHarvester Python executable / venv activation script
THEHARVESTER_PYTHON=python3
THEHARVESTER_PATH=/path/to/vendor/intelligence/theHarvester/theHarvester.py
# Optional: API keys for theHarvester data sources (see theHarvester README)
THEHARVESTER_HUNTER_KEY=
THEHARVESTER_SECURITYTRAILS_KEY=

# ── SpiderFoot ────────────────────────────────────────────────────────────────
SPIDERFOOT_URL=http://localhost:5001
SPIDERFOOT_API_KEY=

# ── check-if-email-exists (Reacher) ──────────────────────────────────────────
# Self-hosted Reacher API endpoint (see vendor/intelligence/check-if-email-exists)
# NOTE: check-if-email-exists is AGPL-licensed. See LEGAL_AND_PLATFORM_RULES.md.
REACHER_BASE_URL=http://localhost:8080
REACHER_API_KEY=

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./data/output
EVIDENCE_DIR=./data/evidence

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Only use with a legal residential/datacenter proxy you subscribe to.
# Leave blank to use your direct IP.
PROXY_URL=
